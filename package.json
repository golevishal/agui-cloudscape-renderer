{
  "name": "aui-cloudscape-renderer",
  "version": "0.1.0",
  "type": "module",
  "description": "Reactive rendering engine bridging the A2UI Protocol with AWS Cloudscape Design System",
  "author": "Vishal Gole",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/golevishal/agui-cloudscape-renderer.git"
  },
  "homepage": "https://github.com/golevishal/agui-cloudscape-renderer#readme",
  "bugs": {
    "url": "https://github.com/golevishal/agui-cloudscape-renderer/issues"
  },
  "keywords": [
    "react",
    "cloudscape",
    "aws",
    "agent-ui",
    "ag-ui",
    "a2ui",
    "renderer",
    "ui",
    "typescript"
  ],
  "main": "./dist-lib/index.js",
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-lib/index.js",
      "types": "./dist-lib/index.d.ts"
    }
  },
  "files": [
    "dist-lib",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && tsc -p tsconfig.lib.json",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "prepublishOnly": "npm run lint && npm run test && npm run build:lib"
  },
  "peerDependencies": {
    "@cloudscape-design/components": "^3.0.0",
    "@cloudscape-design/collection-hooks": "^1.0.0",
    "@cloudscape-design/global-styles": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@cloudscape-design/collection-hooks": "^1.0.87",
    "@cloudscape-design/components": "^3.0.1255",
    "@cloudscape-design/global-styles": "^1.0.54",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
